{
  "name": "devdays-feedback",
  "version": "1.0.0",
  "description": "Conference feedback app - QR codes, quick responses, SQLite",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun --watch run src/server.ts",
    "typecheck": "bunx tsc --noEmit --skipLibCheck",
    "cli": "bun run src/cli.ts",
    "qa-worker": "bun run src/qa-worker.ts",
    "load-talks": "bun run scripts/load-talks.ts",
    "load-ai-context": "bun run scripts/load-ai-context.ts"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
